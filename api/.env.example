# ============================================================================
# Supabase
# Get from: https://supabase.com/dashboard → your project → Settings
# ============================================================================

# Database connection (Settings → Database → Connection string → URI)
# IMPORTANT: Use the "Transaction" pooler (port 6543) for serverless/Vercel
DATABASE_URL=postgresql://postgres.xxxxxx:[YOUR_PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# Supabase API URL & keys (Settings → API)
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...  # service_role key (server-side only, never expose to client)
SUPABASE_BUCKET=media

# App
PORT=3001
NODE_ENV=development
